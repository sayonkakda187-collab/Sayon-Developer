# ── fb-runner environment ─────────────────────────────────────────────────────
# Copy this file to `.env` (cd fb-runner && cp .env.example .env) and fill it in,
# OR just `export` these in your shell before `npm start`. The service reads them
# from the process environment either way. `.env` is gitignored — never commit
# your real token or profile.

# REQUIRED. Shared secret the web app must send as the `x-runner-token` header.
# The SAME value must be set as FB_RUNNER_TOKEN in the web app's environment.
# Generate a strong one:  openssl rand -hex 24
FB_RUNNER_TOKEN="paste-a-long-random-secret-here"

# Port the runner listens on. Default 4350. (NOTE: this is NOT 3000 — 3000 is the
# Next.js dev server. Keep them different so they don't clash when both run.)
FB_RUNNER_PORT="4350"

# Bind address. Keep 127.0.0.1 (localhost-only) unless you intentionally expose
# the runner. If you must reach it from another machine/Vercel, prefer a tunnel
# (cloudflared/ngrok) over binding to 0.0.0.0 — see README + the setup guide.
FB_RUNNER_HOST="127.0.0.1"

# Where the persistent browser profile (your logged-in Facebook session) is
# stored. Default ./profile inside this folder. Keep it PRIVATE — it is your live
# session. Already gitignored.
# FB_PROFILE_DIR="./profile"

# Set to 1 to run the browser HIDDEN (headless). Leave UNSET for the first login
# so you can see the window and log in by hand; switch to 1 only once login works.
# FB_HEADLESS="1"
