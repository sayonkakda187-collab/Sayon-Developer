// Prisma schema for the news publishing website.
//
// Datasource is SQLite for local development. To upgrade to PostgreSQL later,
// change `provider` to "postgresql" and point DATABASE_URL at your connection
// string — no model changes are required. See CLAUDE.md for upgrade notes.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Content ──────────────────────────────────────────────────────────────────

model Article {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String
  content     String // Markdown body
  coverImage  String?
  // Optional attribution when the cover came from a free stock provider (Pexels):
  // photographer name + a link to credit them. Null for manual uploads / pasted URLs.
  coverCredit    String?
  coverCreditUrl String?
  status      String    @default("draft") // "draft" | "published"
  views       Int       @default(0)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  tags           Tag[]           @relation("ArticleTags")
  comments       Comment[]
  scheduledPosts ScheduledPost[]
  dailyViews     DailyView[]

  @@index([status, publishedAt])
  @@index([categoryId])
  // Trigram GIN indexes accelerate case-insensitive substring search (ILIKE)
  // used by the admin article search across these fields.
  @@index([title(ops: raw("gin_trgm_ops"))], type: Gin, map: "Article_title_trgm_idx")
  @@index([excerpt(ops: raw("gin_trgm_ops"))], type: Gin, map: "Article_excerpt_trgm_idx")
  @@index([content(ops: raw("gin_trgm_ops"))], type: Gin, map: "Article_content_trgm_idx")
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())

  articles Article[]
}

model Tag {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique

  articles Article[] @relation("ArticleTags")
}

// ── Engagement ─────────────────────────────────────────────────────────────--

model Comment {
  id         String   @id @default(cuid())
  authorName String
  content    String
  approved   Boolean  @default(false)
  createdAt  DateTime @default(now())

  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId, approved])
}

model Newsletter {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

// Encrypted key-value store for admin-managed settings (e.g. news-search API
// keys + the active provider). Secret values are encrypted at rest with
// AES-256-GCM (lib/crypto.ts) and only ever decrypted server-side — never sent
// to the browser. Non-secret values (like the active provider id) are stored
// plain. One row per setting key.
model AppSetting {
  key       String   @id // e.g. "serpapi_key", "newsapi_key", "news_search_provider"
  value     String // encrypted for *_key entries; plain for non-secret ids
  encrypted Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

// Per-day view counter for the dashboard "views over time" chart. Privacy-
// respecting: just an integer count per article per UTC day — no IP, UA, or any
// visitor PII. Incremented alongside Article.views on each article read.
model DailyView {
  id        String   @id @default(cuid())
  date      DateTime // UTC day (midnight) the views were counted on
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  count     Int      @default(0)

  @@unique([articleId, date])
  @@index([date])
}

// ── Auth ─────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         String   @default("admin")
  avatarUrl    String? // optional admin profile picture (Blob URL); falls back to initials
  createdAt    DateTime @default(now())
}

// ── Facebook Pages integration ───────────────────────────────────────────────
// Official Graph API distribution. Page access tokens are stored ENCRYPTED
// (AES-256-GCM, see lib/crypto.ts) and only ever decrypted server-side.

model FacebookPage {
  id            String   @id @default(cuid())
  pageId        String   @unique // the Facebook Page id
  pageName      String
  accessToken   String // ENCRYPTED long-lived Page access token (never plaintext)
  categoryGroup String // niche/group label, e.g. "US News" | "KH News" | "Entertainment"
  status        String   @default("Connected") // "Connected" | "Expired"
  lastSyncedAt  DateTime? // last successful token validation
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  scheduledPosts ScheduledPost[]

  @@index([categoryGroup])
  @@index([status])
}

// A backed-up logged-in browser session for the self-hosted fb-runner. The
// session is a Playwright storageState (cookies + localStorage) captured after a
// manual login and ENCRYPTED at rest (AES-256-GCM, like FacebookPage.accessToken).
// Reused later to post via the runner without logging in again. A session blob is
// a BEARER credential — never store or log it in plaintext.
model FacebookSession {
  id              String    @id @default(cuid())
  label           String // user-friendly name, e.g. "Sayon — main account"
  accountName     String? // FB display name captured at login (best-effort)
  encryptedState  String // ENCRYPTED storageState JSON (never plaintext)
  status          String    @default("Active") // "Active" | "Expired"
  lastUsedAt      DateTime? // last time a post used this session
  lastValidatedAt DateTime? // last time we confirmed it's still logged in
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
}

model ScheduledPost {
  id             String    @id @default(cuid())
  scheduledFor   DateTime // when it should publish (UTC)
  status         String    @default("pending") // "pending" | "posting" | "posted" | "failed" | "canceled"
  caption        String? // optional edited post caption; null → default message
  postedAt       DateTime?
  error          String? // failure reason, if status = "failed"
  graphPostId    String? // the returned Facebook post id ("{page}_{post}")
  createdAt      DateTime  @default(now())

  articleId      String
  article        Article      @relation(fields: [articleId], references: [id], onDelete: Cascade)
  facebookPageId String
  facebookPage   FacebookPage @relation(fields: [facebookPageId], references: [id], onDelete: Cascade)

  @@index([status, scheduledFor])
  @@index([articleId])
  @@index([facebookPageId])
}
