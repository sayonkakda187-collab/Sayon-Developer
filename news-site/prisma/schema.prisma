// Prisma schema for the news publishing website.
//
// Datasource is SQLite for local development. To upgrade to PostgreSQL later,
// change `provider` to "postgresql" and point DATABASE_URL at your connection
// string — no model changes are required. See CLAUDE.md for upgrade notes.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Content ──────────────────────────────────────────────────────────────────

model Article {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String
  content     String // Markdown body
  // Optional "Key Points" summary: up to a handful of short, original bullet
  // points (newline-separated) shown in a box near the top of the article.
  // Auto-generated by AI on first publish (when empty); editable in the admin.
  keyPoints   String?
  coverImage  String?
  // Optional attribution when the cover came from a free stock provider (Pexels):
  // photographer name + a link to credit them. Null for manual uploads / pasted URLs.
  coverCredit    String?
  coverCreditUrl String?
  // Which free source the cover came from ("Pexels" | "Unsplash" | "Pixabay" |
  // "Wikimedia Commons"). Drives the source-accurate credit line. Null = legacy/manual.
  coverImageSource String?
  status      String    @default("draft") // "draft" | "scheduled" | "published"
  views       Int       @default(0)
  publishedAt DateTime?
  // Scheduled publishing: when status is "scheduled", the article auto-publishes
  // at this UTC instant (via /api/cron/publish-due). Null otherwise.
  scheduledAt DateTime?
  // JSON array of FacebookPage ids to auto-share to AT PUBLISH TIME (set when an
  // article is scheduled with sharing on). Cleared once the share has fired.
  autoSharePageIds String?
  // Human label for where a scheduled item came from, shown in the Scheduled list
  // (e.g. "Auto-Pilot 12:00 run"). Null for manual / agent-approved schedules.
  scheduleSource String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // Multi-site: which Site this article belongs to. Nullable; null is treated as
  // the default site (lib/sites.ts) so existing/legacy rows are never hidden.
  siteId String?
  site   Site? @relation(fields: [siteId], references: [id], onDelete: SetNull)

  tags           Tag[]           @relation("ArticleTags")
  comments       Comment[]
  scheduledPosts ScheduledPost[]
  dailyViews     DailyView[]
  countryViews   ArticleCountryView[]
  deviceViews    ArticleDeviceView[]
  recentViews    RecentView[]

  @@index([status, publishedAt])
  @@index([status, scheduledAt])
  @@index([categoryId])
  @@index([siteId, status, publishedAt])
  // Trigram GIN indexes accelerate case-insensitive substring search (ILIKE)
  // used by the admin article search across these fields.
  @@index([title(ops: raw("gin_trgm_ops"))], type: Gin, map: "Article_title_trgm_idx")
  @@index([excerpt(ops: raw("gin_trgm_ops"))], type: Gin, map: "Article_excerpt_trgm_idx")
  @@index([content(ops: raw("gin_trgm_ops"))], type: Gin, map: "Article_content_trgm_idx")
}

// ── Sites (multi-site foundation) ────────────────────────────────────────────
// A Site = one news property (its own domain + content). For now there is ONE
// default site (= the current site); multi-site is latent structure (no domain
// routing / per-site branding/ads/FB yet — see CLAUDE.md). Categories and Tags
// are SHARED across sites for now. logo/title/description are future-branding
// placeholders, not wired to the frontend.
model Site {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  domain      String?  @unique // public hostname (null until assigned); routing is future work
  isDefault   Boolean  @default(false)
  logo        String? // future per-site branding (unused for now)
  title       String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  articles Article[]

  @@index([isDefault])
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())

  articles Article[]
}

model Tag {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique

  articles Article[] @relation("ArticleTags")
}

// ── Engagement ─────────────────────────────────────────────────────────────--

model Comment {
  id         String   @id @default(cuid())
  authorName String
  content    String
  approved   Boolean  @default(false)
  createdAt  DateTime @default(now())

  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId, approved])
}

model Newsletter {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

// Encrypted key-value store for admin-managed settings (e.g. news-search API
// keys + the active provider). Secret values are encrypted at rest with
// AES-256-GCM (lib/crypto.ts) and only ever decrypted server-side — never sent
// to the browser. Non-secret values (like the active provider id) are stored
// plain. One row per setting key.
model AppSetting {
  key       String   @id // e.g. "serpapi_key", "newsapi_key", "news_search_provider"
  value     String // encrypted for *_key entries; plain for non-secret ids
  encrypted Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

// Per-day view counter for the dashboard "views over time" chart. Privacy-
// respecting: just an integer count per article per UTC day — no IP, UA, or any
// visitor PII. Incremented alongside Article.views on each article read.
model DailyView {
  id        String   @id @default(cuid())
  date      DateTime // UTC day (midnight) the views were counted on
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  count     Int      @default(0)

  @@unique([articleId, date])
  @@index([date])
}

// Per-country visitor counts for the admin Audience analytics. Privacy-respecting:
// only an integer count per article per ISO country per UTC day — no IP, UA, or
// any visitor PII. Country comes from the free Vercel `x-vercel-ip-country`
// request header; missing/unknown → "ZZ". Incremented alongside the view counters.
model ArticleCountryView {
  id          String   @id @default(cuid())
  date        DateTime // UTC day (midnight) the views were counted on
  articleId   String
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  countryCode String // ISO 3166-1 alpha-2 (uppercase); "ZZ" = unknown
  count       Int      @default(0)

  @@unique([articleId, countryCode, date])
  @@index([countryCode])
  @@index([date])
}

// Per-device-type visitor counts for the admin Audience analytics. Privacy-
// respecting: only an integer count per article per device class per UTC day —
// no IP, no stored UA string, no visitor PII. The device class
// (mobile/desktop/tablet) is derived from the request User-Agent at read time and
// immediately discarded — only the bucket is kept. Incremented alongside the
// other view counters.
model ArticleDeviceView {
  id        String   @id @default(cuid())
  date      DateTime // UTC day (midnight) the views were counted on
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  device    String // "mobile" | "desktop" | "tablet"
  count     Int      @default(0)

  @@unique([articleId, device, date])
  @@index([device])
  @@index([date])
}

// Short-lived real-time read log powering the Audience "Live readers" panel: one
// row per article view (timestamp + country), pruned to a ~15-minute window on
// write so it stays tiny. This is NOT analytics history (that's DailyView /
// ArticleCountryView) — just "who's reading right now". Privacy-respecting: an
// aggregate country code only (free Vercel geo header), never IP/UA/PII.
model RecentView {
  id          String   @id @default(cuid())
  articleId   String
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  countryCode String   @default("ZZ") // ISO 3166-1 alpha-2; "ZZ" = unknown
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

// ── Auth ─────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         String   @default("admin")
  avatarUrl    String? // optional admin profile picture (Blob URL); falls back to initials
  createdAt    DateTime @default(now())
}

// ── Facebook Pages integration ───────────────────────────────────────────────
// Official Graph API distribution. Page access tokens are stored ENCRYPTED
// (AES-256-GCM, see lib/crypto.ts) and only ever decrypted server-side.

model FacebookPage {
  id            String   @id @default(cuid())
  pageId        String   @unique // the Facebook Page id
  pageName      String
  accessToken   String // ENCRYPTED long-lived Page access token (never plaintext)
  categoryGroup String // niche/group label, e.g. "US News" | "KH News" | "Entertainment"
  status        String   @default("Connected") // "Connected" | "Expired"
  // Cached Page profile picture: the public Facebook CDN URL (NO token in it),
  // resolved server-side via /{pageId}/picture with the Page token. Refreshed in
  // the sync / reconnect / insights flows; FB CDN URLs expire, so it's re-fetched
  // when older than ~7 days or when the stored URL stops loading. Null = silhouette
  // / not set → the UI shows a coloured initial instead.
  avatarUrl       String?
  avatarFetchedAt DateTime?
  // Optional operational problem flag the admin sets (e.g. "Limited post",
  // "Post failed", "Verify identity") to surface a Page in the manager's
  // "Needs attention" box — independent of the token `status`. Null = healthy.
  issue         String?
  lastSyncedAt  DateTime? // last successful token validation
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  scheduledPosts ScheduledPost[]
  insightCache   PageInsightCache?
  dailyCache     PageDailyCache[]
  postsCache     PagePostsCache?

  @@index([categoryGroup])
  @@index([status])
}

// ~12h cache of a Page's computed Insights overview (followers / 28-day reach /
// 28-day engagement + status), so the Insights tab doesn't re-hit the Graph API
// for ~264 Pages on every load. One row per Page; data is a small JSON snapshot.
model PageInsightCache {
  facebookPageId String       @id
  facebookPage   FacebookPage @relation(fields: [facebookPageId], references: [id], onDelete: Cascade)
  data           String // JSON: { followers, reach28, engagement28, status }
  fetchedAt      DateTime     @default(now())
}

// Per-(Page, date-range) cache of the day-by-day insights series (reach /
// engagement / follows per day), so the Insights day view doesn't re-hit the
// Graph API for every Page on each range change. `rangeKey` is "from_to" (PP
// dates); short TTL for ranges that include today (partial/changing), longer for
// fully-historical ranges. One row per Page per range.
model PageDailyCache {
  facebookPageId String
  rangeKey       String
  facebookPage   FacebookPage @relation(fields: [facebookPageId], references: [id], onDelete: Cascade)
  data           String // JSON: DayPoint[] = [{ date, reach, engagement, follows }]
  fetchedAt      DateTime     @default(now())

  @@id([facebookPageId, rangeKey])
}

// ~6h cache of a Page's REAL published posts (the first page of ~15, pulled live
// from the Graph API for the Page Control → Content view). One row per Page; lets
// opening a Page's dashboard show its posts without re-hitting Graph each time —
// essential at ~264 Pages on Vercel Hobby. `data` is a small JSON snapshot
// { posts: PagePost[], after: cursor|null }. "Load more" (cursor paging) and
// Refresh fetch live; Refresh also rewrites this first-page cache.
model PagePostsCache {
  facebookPageId String       @id
  facebookPage   FacebookPage @relation(fields: [facebookPageId], references: [id], onDelete: Cascade)
  data           String // JSON: { posts: PagePost[], after: string | null }
  fetchedAt      DateTime     @default(now())
}

// A backed-up logged-in browser session for the self-hosted fb-runner. The
// session is a Playwright storageState (cookies + localStorage) captured after a
// manual login and ENCRYPTED at rest (AES-256-GCM, like FacebookPage.accessToken).
// Reused later to post via the runner without logging in again. A session blob is
// a BEARER credential — never store or log it in plaintext.
model FacebookSession {
  id              String    @id @default(cuid())
  label           String // user-friendly name, e.g. "Sayon — main account"
  accountName     String? // FB display name captured at login (best-effort)
  encryptedState  String // ENCRYPTED storageState JSON (never plaintext)
  status          String    @default("Active") // "Active" | "Expired"
  lastUsedAt      DateTime? // last time a post used this session
  lastValidatedAt DateTime? // last time we confirmed it's still logged in
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
}

model ScheduledPost {
  id             String    @id @default(cuid())
  scheduledFor   DateTime // when it should publish (UTC)
  status         String    @default("pending") // "pending" | "posting" | "posted" | "failed" | "canceled"
  caption        String? // optional edited post caption; null → default message
  postedAt       DateTime?
  error          String? // failure reason, if status = "failed"
  graphPostId    String? // the returned Facebook post id ("{page}_{post}")
  // Share mode used ("link" | "photo"). Photo mode also stores the link-comment id
  // (or commentError when the post landed but the comment didn't — retryable).
  mode           String? // null = legacy "link"
  commentId      String?
  commentError   String?
  createdAt      DateTime  @default(now())

  articleId      String
  article        Article      @relation(fields: [articleId], references: [id], onDelete: Cascade)
  facebookPageId String
  facebookPage   FacebookPage @relation(fields: [facebookPageId], references: [id], onDelete: Cascade)

  @@index([status, scheduledFor])
  @@index([articleId])
  @@index([facebookPageId])
}
