# Copy this file to `.env` and adjust as needed.

# SQLite (default for local development) — relative to the prisma/ directory.
DATABASE_URL="file:./dev.db"

# PostgreSQL (production example):
# DATABASE_URL="postgresql://user:password@localhost:5432/news?schema=public"

# Secret used to sign admin session cookies (use a long random value in prod,
# e.g. `openssl rand -hex 32`).
AUTH_SECRET="dev-insecure-secret-change-me"

# Optional: override the seeded admin credentials before running the seed.
# ADMIN_EMAIL="admin@example.com"
# ADMIN_PASSWORD="admin1234"
