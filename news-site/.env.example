# Copy this file to `.env` and adjust. `.env` is gitignored — never commit secrets.

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Local dev (matches docker-compose.yml — run `docker compose up -d`):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/newsdb?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/newsdb?schema=public"
#
# Production (Neon / Vercel Postgres):
#   DATABASE_URL -> POOLED connection (used at runtime)
#   DIRECT_URL   -> NON-pooled connection (used for migrations)
#   e.g.
#   DATABASE_URL="postgres://user:pass@ep-xxx-pooler.us-east-2.aws.neon.tech/db?sslmode=require"
#   DIRECT_URL="postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/db?sslmode=require"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Signs admin session cookies. REQUIRED in production (the app refuses the dev
# fallback when NODE_ENV=production). Generate one with: openssl rand -hex 32
AUTH_SECRET="dev-insecure-secret-change-me"

# Seeded admin account (used by `npm run db:seed` / `npm run db:reset`).
# REQUIRED in production (seeding throws if unset); dev defaults to
# admin@example.com / admin1234.
# ADMIN_EMAIL="you@example.com"
# ADMIN_PASSWORD="use-a-strong-password"

# ── Facebook Pages integration (Graph API) ───────────────────────────────────
# Page access tokens are encrypted at rest (AES-256-GCM). Set a dedicated key in
# production; if unset, the app falls back to AUTH_SECRET. REQUIRED in production
# (encryption throws if neither is set). Generate one with: openssl rand -hex 32
# ENCRYPTION_KEY="generate-with-openssl-rand-hex-32"
#
# Secures the scheduled-post cron route (/api/cron/facebook-post). Vercel Cron
# sends it as `Authorization: Bearer <CRON_SECRET>`. REQUIRED in production — if
# unset, the cron route refuses to run on the live site (fail closed).
# CRON_SECRET="generate-with-openssl-rand-hex-32"
#
# Only needed if you exchange short-lived USER tokens for long-lived ones in the
# Connect dialog. Not required if you paste long-lived PAGE tokens directly.
# FACEBOOK_APP_ID="your-facebook-app-id"
# FACEBOOK_APP_SECRET="your-facebook-app-secret"
#
# Optional: pin the Graph API version (defaults to v21.0).
# FACEBOOK_GRAPH_VERSION="v21.0"
#
# Optional self-hosted BROWSER RUNNER (persistent-browser posting; see /fb-runner).
# When BOTH are set, the Facebook panel offers a "Browser runner" posting method
# that drives a manually-logged-in browser instead of the Graph API. The runner
# CANNOT run on Vercel (needs a long-lived process) — host it yourself and point
# this at it. Server-side only. Leave unset to use the Graph API as normal.
# ⚠️ Automating a logged-in Facebook session is against Facebook's ToS and can
# get the account disabled — use at your own risk.
# FB_RUNNER_URL="http://127.0.0.1:4350"
# FB_RUNNER_TOKEN="match-the-token-set-in-the-runner"
#
# Public origin for ALL canonical tags, og:url, twitter tags, the sitemap, and
# absolute links. IMPORTANT: this is a NEXT_PUBLIC_* var — it's inlined at BUILD
# time, so it must be set in Vercel (Production + Preview) BEFORE/at build and a
# redeploy is needed after changing it. If unset, production safely falls back to
# https://dailyledger.today (never localhost), so share previews always resolve.
# NEXT_PUBLIC_SITE_URL="https://dailyledger.today"

# ── Trending News (multi-source aggregation) ──────────────────────────────────
# The admin "Trending News" page aggregates several FREE news APIs into one
# deduped feed. Each key is OPTIONAL and independent: set the ones you want; a
# source with no key is simply skipped (shown as "not set up"), and the others
# still work. ALL keys are server-side ONLY — never exposed to the browser.
# Results are cached in-memory ~20 min PER SOURCE so a combined feed doesn't burn
# any single free tier. Add each in Vercel → Settings → Environment Variables for
# Production + Preview, then redeploy.
#
# These are all LIMITED free tiers — combining them gives more coverage, but for
# truly high volume a PAID plan on one provider would be needed.
#
# GNews — register: https://gnews.io  (free: ~100 req/day, 10 articles/req)
# GNEWS_API_KEY="your-free-gnews-api-key"
#
# NewsData.io — register: https://newsdata.io  (free: ~200 credits/day, 10/req) — recommended
# NEWSDATA_API_KEY="your-free-newsdata-key"
#
# TheNewsAPI — register: https://www.thenewsapi.com  (free: ~100 req/day, 3 articles/req)
# THENEWSAPI_KEY="your-free-thenewsapi-key"
#
# Currents API — register: https://currentsapi.services  (free dev tier: ~600 req/day) — optional
# CURRENTSAPI_KEY="your-free-currents-key"
#
# NOT SUPPORTED for production: NewsAPI.org's free tier is Developer-only and is
# blocked on live/deployed domains (localhost only), so it's intentionally not
# integrated. Mediastack's free tier is HTTP-only (breaks on an HTTPS site) +
# ~100/month, so it's skipped too.

# ── News Search (paid metasearch: SerpApi / NewsAPI) ──────────────────────────
# Powers the "News Search" tab on the Trending page (keyword + category + region
# + language). These keys can be pasted in the admin "API Settings" tab (stored
# ENCRYPTED in the DB — requires ENCRYPTION_KEY/AUTH_SECRET above) OR set here as
# an env fallback. A DB-saved key takes priority. Server-side ONLY — never sent
# to the browser. Results are cached ~20 min to protect paid quota.
#
# ⚠️ PAID: SerpApi has only a small free trial (~100 searches), then it costs
# money. NewsAPI.org's FREE tier is DEVELOPMENT-ONLY (not allowed on a live
# site) — production needs its paid plan. The free Trending feed above (GNews +
# aggregated free APIs) remains available if you'd rather not pay.
#
# SerpApi (Google News) — https://serpapi.com
# SERPAPI_KEY="your-serpapi-key"
# NewsAPI.org — https://newsapi.org
# NEWSAPI_KEY="your-newsapi-key"

# ── AI Assist (Anthropic Claude) ──────────────────────────────────────────────
# Powers the "AI Assist" button on the Trending News page: from a HEADLINE +
# topic only (never scraped source text), it drafts a brief, headline options,
# an outline, background/angles, and an ORIGINAL first draft you must fact-check
# + edit. The draft opens in the editor as an UNSAVED draft — never auto-published.
#
# ⚠️ PAID, pay-per-use (UNLIKE the free GNews tier). It only runs when you click
# "AI Assist" — never automatically — so cost tracks your usage. With the default
# model (claude-haiku-4-5) expect roughly ~1¢ per generation; a few dollars of
# credit lasts a long time. Get a key at https://console.anthropic.com → API
# Keys, add a little billing credit, then paste it here. Server-side ONLY — never
# sent to the browser. In Vercel, add it under Project → Settings → Environment
# Variables for Production & Preview, then redeploy. If unset, the AI Assist
# button shows a "Set up AI" state instead of erroring.
# ANTHROPIC_API_KEY="sk-ant-..."
#
# Optional: the DEFAULT model. There's also an in-app model picker (Haiku 4.5 /
# Sonnet 4.6 / Opus 4.8) that remembers your choice per browser and overrides
# this per generation. This env just sets the fallback default when no pick is
# made. Haiku ~1¢, Sonnet ~3-5¢, Opus pricier (higher quality) per generation.
# ANTHROPIC_MODEL="claude-haiku-4-5-20251001"

# ── Free stock photos (Pexels) ────────────────────────────────────────────────
# Powers "Search free photos" / "Suggest from title" in the editor's cover-image
# area. License-cleared images only (https://www.pexels.com/license/) — never
# news-source images. FREE: register at https://www.pexels.com/api/ (no card),
# limit ~200 requests/hour — searches are cached server-side ~30 min to stay well
# under it. Server-side ONLY; never sent to the browser. Add in Vercel → Settings
# → Environment Variables (Production & Preview), then redeploy. If unset, the
# "Search free photos" buttons show a tidy "set up photos" state and manual
# upload still works.
# PEXELS_API_KEY="your-free-pexels-api-key"

# ── AI image generation (swappable provider) ──────────────────────────────────
# Powers the "AI Images" admin tab and the editor's "Generate with AI" cover
# button: a text prompt → illustration(s) you can download, save to media (Blob),
# or set as an article cover. Server-side ONLY — keys are never sent to the
# browser; only the resulting image is. If none is set, the feature shows a tidy
# "set up" state and everything else (stock photos, manual upload) still works.
#
# Pick ANY ONE provider below. By default the active provider is AUTO-DETECTED
# from whichever keys are present; set IMAGE_PROVIDER to force one.
# IMAGE_PROVIDER="cloudflare"   # cloudflare | huggingface | gemini
#
# ⚠️ NEWS SAFETY: AI images are for illustrations / concept art / stylized
# graphics — never present them as real photos of real news events. For real
# events, use the Pexels stock-photo search instead.
#
# 1) Cloudflare Workers AI — FREE daily quota, no credit card (recommended).
#    Account ID: Cloudflare dashboard → Workers & AI (right sidebar). Token:
#    https://dash.cloudflare.com/profile/api-tokens → Create Token → "Workers AI"
#    template (read). Default model FLUX.1 [schnell]; override with CLOUDFLARE_IMAGE_MODEL.
# CLOUDFLARE_ACCOUNT_ID="your-cloudflare-account-id"
# CLOUDFLARE_API_TOKEN="your-workers-ai-token"
# CLOUDFLARE_IMAGE_MODEL="@cf/black-forest-labs/flux-1-schnell"
#
# 2) Hugging Face Inference — FREE tier, no card. Token (Read):
#    https://huggingface.co/settings/tokens. A cold model may need ~30s to warm up
#    (shown as "warming up — try again"). Override the model with HF_IMAGE_MODEL.
# HF_API_TOKEN="hf_xxx"                            # (HUGGINGFACE_API_KEY also accepted)
# HF_IMAGE_MODEL="black-forest-labs/FLUX.1-schnell"
#
# 3) Google Gemini / Imagen — key at https://aistudio.google.com/apikey.
#    ⚠️ In 2026 Google's FREE image tier is limited: many keys return HTTP 429
#    "limit: 0" for image models (e.g. gemini-2.5-flash-image) unless BILLING is
#    enabled on the Cloud project (then ~$0.039/image). Imagen models have NO free
#    tier. Try IMAGE_GEN_MODEL=gemini-2.5-flash-image; if it still says limit:0,
#    enable billing or use Cloudflare / Hugging Face above. Errors are shown verbatim.
# GEMINI_API_KEY="your-google-ai-studio-key"      # (IMAGE_API_KEY also accepted)
# IMAGE_GEN_MODEL="gemini-2.5-flash-image"        # or an imagen-* id (needs billing)

# ── Image uploads (Vercel Blob) ───────────────────────────────────────────────
# When set, admin image uploads go to Vercel Blob. REQUIRED in production —
# Vercel's filesystem is read-only. Connecting a Blob store in the Vercel
# dashboard injects this automatically. If unset, uploads fall back to
# ./public/uploads (local dev only).
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"

# ── Reserved AdSense slots (layout prep) ──────────────────────────────────────
# Master switch for the RESERVED Google AdSense placements (in-article, end of
# article, homepage). SEPARATE from the AdsKeeper system in lib/ads.ts (which is
# unaffected). Default OFF: when off, the slots render NOTHING (no gaps). When on
# they reserve min-height to avoid layout shift — but NO real <ins class=
# "adsbygoogle"> ships until your AdSense account is approved (structure only).
# You can also toggle this from Admin → Settings (stored in AppSetting); whichever
# of the env flag / the setting is on wins.
# ADSENSE_ENABLED="false"
