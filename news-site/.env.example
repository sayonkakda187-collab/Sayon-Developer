# Copy this file to `.env` and adjust as needed.

# SQLite (default for local development) — relative to the prisma/ directory.
DATABASE_URL="file:./dev.db"

# PostgreSQL (production example):
# DATABASE_URL="postgresql://user:password@localhost:5432/news?schema=public"

# Secret used to sign admin session cookies.
#   Local dev: optional — a dev-only fallback applies if unset.
#   Production: REQUIRED — admin auth refuses the insecure fallback in prod.
#   Generate one with:  openssl rand -hex 32
AUTH_SECRET="dev-insecure-secret-change-me"

# Seeded admin account, used by `npm run db:seed` / `npm run db:reset`.
#   Local dev: optional — defaults to admin@example.com / admin1234.
#   Production: REQUIRED — seeding throws if these are unset.
# ADMIN_EMAIL="you@example.com"
# ADMIN_PASSWORD="use-a-strong-password"
